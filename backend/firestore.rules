rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidFieldReport(data) {
      return data.userId is string &&
             data.timestamp is string &&
             data.cropType is string &&
             data.healthStatus in ['Healthy', 'Stressed', 'Diseased', 'Unknown'];
    }

    match /fieldReports/{reportId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidFieldReport(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidFieldReport(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /healthHistory/{historyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
